# --- MongoDB ---
# Connection string from MongoDB Atlas (or any MongoDB instance).
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority"
# Database name (optional, defaults to "cisne").
MONGODB_DB="cisne"

# --- Vercel Blob ---
# Read/write token for Vercel Blob storage.
# On Vercel this is injected automatically when you connect a Blob store.
# For local dev, create one in the Vercel dashboard: Storage > Blob > .env.local tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# --- Admin panel ---
# The single password used to log in to /admin.
ADMIN_PASSWORD="change-me-to-something-strong"
# Secret used to sign the admin session cookie. Use a long random string.
# Generate one with:  openssl rand -base64 48
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
